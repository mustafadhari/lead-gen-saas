# ── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ── Vapi (AI Voice Calling) ──────────────────────────
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_ASSISTANT_ID=
VAPI_DAILY_CALL_LIMIT=10

# ── Resend (Email) ───────────────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alex@yourdomain.com
RESEND_FROM_NAME=Alex

# ── Upstash Redis (Queue) ────────────────────────────
UPSTASH_REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-upstash-rest-token

# ── Queue Settings ──────────────────────────────────
QUEUE_MAX_PER_HOUR=10
QUEUE_JOB_RETRIES=3
QUEUE_RETRY_DELAY_MS=60000
POLL_INTERVAL_CRON=*/5 * * * *

# ── Crawler ─────────────────────────────────────────
CRAWL_DELAY_MS=2000
CRAWL_MAX_RETRIES=3

# ── Testing ──────────────────────────────────────────
TEST_MODE=false
TEST_PHONE_NUMBER=+1234567890
TEST_EMAIL=test@example.com

# ── Krayin CRM ────────────────────────────────────────
# Run: cd crm && php artisan tinker (see README-CRM.md)
KRAYIN_BASE_URL=http://localhost:8000
KRAYIN_API_TOKEN=your-sanctum-token-here
KRAYIN_PIPELINE_ID=1
KRAYIN_STAGE_ID=1
KRAYIN_SOURCE_ID=1
